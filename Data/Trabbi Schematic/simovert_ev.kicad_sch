  (label "P9_PWR_RED_IND" (at 830.000 140.000 0)
    (effects (font (size 1.27 1.27)))
    (uuid "8b2a6a47-27d2-422e-a07c-f5ddb20fd932")
  )
  (text "P2_EMERG_OFF: Connect to GND via E-stop switch (RED-GRN)" (at 50.000 420.000 0)
    (effects (font (size 1.000 1.000)))
    (uuid "7ba15116-a1fc-49d2-bf3d-5d209c20297f")
  )
  (text "P20_PWR_REDUCE: GND = normal power, open/+12V = reduced (RED-BRN)" (at 50.000 426.000 0)
    (effects (font (size 1.000 1.000)))
    (uuid "9ed4cdf6-af8c-46de-aadb-2e037c7489b1")
  )
  (text "P29_REGEN_EN: GND = regen braking enabled (BLK wire)" (at 50.000 432.000 0)
    (effects (font (size 1.000 1.000)))
    (uuid "a4ca9edf-6f76-41f2-961d-e51970b150f8")
  )
  (text "P31_START_INH: GND = start allowed (GRY wire)" (at 50.000 438.000 0)
    (effects (font (size 1.000 1.000)))
    (uuid "324b5465-6a60-4a55-ad1d-f1db7a458d35")
  )
  (text "P21_VEH_SPEED: frequency input 0.7-250Hz (PNK wire)" (at 50.000 444.000 0)
    (effects (font (size 1.000 1.000)))
    (uuid "3bc274c9-e885-416f-89c3-a1d506db91c0")
  )
  (text "P10_MOT_SPD: frequency output (ORG-RED wire, 4.7kOhm pullup to +12V)" (at 50.000 450.000 0)
    (effects (font (size 1.000 1.000)))
    (uuid "41bda5f4-fb43-4947-b248-5814c7b5aa4d")
  )
  (text "X4: motor encoder interface cable (12-wire cable)" (at 50.000 456.000 0)
    (effects (font (size 1.000 1.000)))
    (uuid "676da09d-636c-4a88-8707-a23664b5805a")
  )
  (text "X5: RS232 diagnostic (SIADIS software, 9600 baud COM1)" (at 50.000 462.000 0)
    (effects (font (size 1.000 1.000)))
    (uuid "858eb499-2cb9-4911-ac9b-eca63b45d555")
  )
  (text "INSTALLATION NOTES (Simovert 6SV1 Long Inverter):" (at 50.000 600.000 0)
    (effects (font (size 1.500 1.500)))
    (uuid "7f3ba55c-c869-49e5-b921-61ec6d01bd1b")
  )
  (text "1. KL31 (M6 bolt on case) = -12V DC-DC output. Connect DIRECTLY to BT2- with 10mm2 wire. CRITICAL!" (at 50.000 608.000 0)
    (effects (font (size 1.100 1.100)))
    (uuid "03c9baaa-e543-4033-b7be-6861a51da1ea")
  )
  (text "2. Connect KL31 FIRST, disconnect LAST. Disconnecting while on WILL damage interface PCB." (at 50.000 614.000 0)
    (effects (font (size 1.100 1.100)))
    (uuid "f060a2f1-4de5-4982-b070-b36f740b894f")
  )
  (text "3. Traction battery (HV) is isolated from chassis. Only KL31/case connects to chassis GND." (at 50.000 620.000 0)
    (effects (font (size 1.100 1.100)))
    (uuid "914488c6-9b84-49d8-8a39-a33ece856203")
  )
  (text "4. Motor case must be connected to vehicle chassis (GND_CHASSIS)." (at 50.000 626.000 0)
    (effects (font (size 1.100 1.100)))
    (uuid "0ccc7811-90c8-4b18-81aa-8982919cd9bf")
  )
  (text "5. CB1: 300A circuit breaker in positive HV cable. F1: 40A fuse." (at 50.000 632.000 0)
    (effects (font (size 1.100 1.100)))
    (uuid "76eca7ab-cd92-401d-a4c8-6c107ff38154")
  )
  (text "6. Coolant: flow INTO inverter first, then TO motor. Min 8 l/min. Max inlet 55 degC." (at 50.000 638.000 0)
    (effects (font (size 1.100 1.100)))
    (uuid "03e92c5d-64e4-4b00-aa7e-ba5f84ad4115")
  )
  (text "7. Never connect/disconnect X1, X4, X5 while ignition is ON." (at 50.000 644.000 0)
    (effects (font (size 1.100 1.100)))
    (uuid "b677ea2d-5049-42f9-9fdc-8f554efef807")
  )
  (text "8. AccPedRel must read 0% in SIADIS before main contactor will close." (at 50.000 650.000 0)
    (effects (font (size 1.100 1.100)))
    (uuid "37004b3c-5770-4922-bcef-bc1fd1e39e3f")
  )
  (text "9. Motor L1→L1, L2→L2, L3→L3 (polarity matters for rotation direction, bit 1 of Mode_Selector)." (at 50.000 656.000 0)
    (effects (font (size 1.100 1.100)))
    (uuid "1beef62e-57bb-414a-8fc8-db308ac23ef2")
  )
  (text "10. For regen braking: X1/P29 (BLK) must be pulled to GND." (at 50.000 662.000 0)
    (effects (font (size 1.100 1.100)))
    (uuid "b6adfc93-9cd9-4941-b3b5-948aea238549")
  )
  (text "WIRE COLOR REFERENCE (Appendix C, Long Inverter):" (at 700.000 600.000 0)
    (effects (font (size 1.400 1.400)))
    (uuid "00280dd1-240d-4de6-84df-d65ee3b81fff")
  )
  (text "X1/P1   FAT RED 1.5mm2        Ignition drive position" (at 700.000 610.000 0)
    (effects (font (size 0.900 0.900)))
    (uuid "dc43e1b3-26d1-4573-a2dd-da0b6959787a")
  )
  (text "X1/P2   RED/GRN 0.5mm2        Emergency power off" (at 700.000 615.000 0)
    (effects (font (size 0.900 0.900)))
    (uuid "c798557b-2f4c-42d8-b4d3-bd7ffa2b1729")
  )
  (text "X1/P4   BRN 1.5mm2            Fan (-)" (at 700.000 620.000 0)
    (effects (font (size 0.900 0.900)))
    (uuid "ee14c14b-65f0-46bb-8d23-0153e09e32cb")
  )
  (text "X1/P7   GRN 0.5mm2            Failure: power inverter" (at 700.000 625.000 0)
    (effects (font (size 0.900 0.900)))
    (uuid "86514274-6ab0-4d98-84be-e5274c5e4939")
  )
